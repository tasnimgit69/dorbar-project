---
import type { ImageMetadata } from 'astro';
import { resolveImage } from '../../utils/resolveImage';

const bgImage = resolveImage('/images/backgrounds/team-section-bg-min.webp') as ImageMetadata;
---

<section class="hero-section info" style={`--bg-image: url('${bgImage.src}')`}>
  <div class="container-default">
    <div class="hero-wrapper">
      <div class="hero-content-wrap max-w-800">
        <div class="section-subtitle-block-two">
          <div class="section-subtitle-liner-one"></div>
          <div class="section-subtitle-text-two">Style Guide</div>
          <div class="section-subtitle-liner-two"></div>
        </div>
        <h1 class="hero-section-title">Style Guide for Dorbar Template</h1>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.hero-section.info');
    if (!section) return;

    const subtitle = section.querySelector('.section-subtitle-block-two');
    const title = section.querySelector('.hero-section-title');

    const elements = [
      { el: subtitle, delay: 0.2 },
      { el: title, delay: 0.4 },
    ];

    elements.forEach(({ el, delay }) => {
      if (!el) return;
      gsap.set(el, { y: 100, opacity: 0 });
      gsap.to(el, {
        y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay,
        scrollTrigger: { trigger: section, start: 'top 80%', once: true }
      });
    });
  });
</script>
