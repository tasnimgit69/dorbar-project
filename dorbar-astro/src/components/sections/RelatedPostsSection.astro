---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { BlogPost } from '../../data/blogPosts';
import { resolveImage } from '../../utils/resolveImage';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;

const clockIcon = resolveImage('/images/icons/clock-icon.svg') as ImageMetadata;
const userIcon = resolveImage('/images/icons/user-icon.svg') as ImageMetadata;
---

<section class="bog-section" id="Blog-Related-Section">
  <div class="section-gap bottom">
    <div class="container-default">
      <div class="blog-wrapper">
        <div class="section-heading-block">
          <h2 class="section-title-two">More Legal Insights</h2>
        </div>
        <div class="blog-content-block blog-page desktop">
          <div class="blog-collection-list-block">
            <div class="blog-collection-list is-3 blog-page">
              {posts.map((related) => (
                <div class="blog-collection-item">
                  <div class="blog-item-card-block">
                    <a aria-label={related.title} href={`/blog-post/${related.slug}`} class="blog-item-image-block">
                      <Image src={resolveImage(related.image) as ImageMetadata} loading="lazy" alt={related.title} class="blog-item-image blog-page" width={600} height={400} />
                      <div class="blog-category-text">{related.category}</div>
                    </a>
                    <div class="blog-item-content-block">
                      <div class="blog-item-info-block">
                        <div class="blog-single-info-block">
                          <Image src={clockIcon} loading="lazy" alt="Blog Info Icon" class="blog-info-icon" width={16} height={16} />
                          <p class="blog-info-text">{related.date}</p>
                        </div>
                        <div class="blog-single-info-block">
                          <Image src={userIcon} loading="lazy" alt="Blog Info Icon" class="blog-info-icon" width={16} height={16} />
                          <div class="blog-info-text-block">
                            <p class="blog-info-text">By</p>
                            <p class="blog-info-text">{related.author}</p>
                          </div>
                        </div>
                      </div>
                      <a aria-label={related.title} href={`/blog-post/${related.slug}`} class="blog-item-title-block">
                        <h3 class="blog-item-title">{related.title}</h3>
                      </a>
                      <div class="blog-item-summary-block">
                        <p class="blog-item-summary">{related.summary}</p>
                      </div>
                      <a href={`/blog-post/${related.slug}`} class="link-button-block">
                        <div class="link-button-content">
                          <div class="link-button-text sm">Read Article</div>
                          <div class="link-button-icon">
                            <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M1 5H10.3333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"></path>
                              <path d="M7 1L11 5L7 9" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                          </div>
                        </div>
                        <div class="link-button-liner"></div>
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const relatedSection = document.querySelector('#Blog-Related-Section');
  if (relatedSection) {
    const heading = relatedSection.querySelector('.section-title-two');
    const cards = relatedSection.querySelectorAll('.blog-collection-item') as NodeListOf<HTMLElement>;

    if (heading) {
      gsap.fromTo(heading, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: relatedSection, start: 'top 80%', once: true },
      });
    }

    cards.forEach((card, i) => {
      gsap.fromTo(card, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: ((i % 3) + 1) * 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: relatedSection, start: 'top 80%', once: true },
      });
    });
  }
</script>
