---
import { subjectOptions } from '../../data/contact';
import { siteConfig } from '../../data/siteConfig';
---

<section id="Contact-Us-Two" class="contact-us-section">
  <div class="section-gap-two">
    <div class="container-default">
      <div class="contact-us-wrapper-two">
        <div class="contact-content-block-two">
          <div class="contact-form-sticky-block-two">
            <div class="contact-form-block-two">
              <div class="contact-form-block">
                <form id="contact-form" name="contact-form" class="contact-form-inner-two" method="post">
                  <div class="contact-form-content-block-two">
                    <div class="form-title-block-two bottom-16px-gap">
                      <h2 class="form-title-two">Send a Message</h2>
                    </div>
                    <div class="form-field-block-two">
                      <label for="name" class="form-field-label-two">Full Name *</label>
                      <input class="form-text-field-two" maxlength="256" name="name" placeholder="John Doe" type="text" id="name" required />
                    </div>
                    <div class="form-field-block-two">
                      <label for="email" class="form-field-label-two">Email Address *</label>
                      <input class="form-text-field-two" maxlength="256" name="email" placeholder="john@example.com" type="email" id="email" required />
                    </div>
                    <div class="form-field-block-two">
                      <label for="phone" class="form-field-label-two">Phone Number</label>
                      <input class="form-text-field-two" maxlength="256" name="phone" placeholder="(123) 4567-890" type="tel" id="phone" />
                    </div>
                    <div class="form-field-block-two">
                      <label for="subject" class="form-field-label-two">Subject</label>
                      <select id="subject" name="subject" class="form-text-field-two select">
                        <option value="">Select a Topic...</option>
                        {subjectOptions.map((opt) => (
                          <option value={opt}>{opt}</option>
                        ))}
                      </select>
                    </div>
                    <div class="form-field-block-two">
                      <label for="message" class="form-field-label-two">Your Message</label>
                      <textarea placeholder="Please describe your legal matter briefly..." maxlength="5000" id="message" name="message" class="form-text-field-two lg"></textarea>
                    </div>
                  </div>
                  <div class="form-button-block-two">
                    <button type="submit" class="form-button two">Send Message</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
          <div class="contact-information-block-two">
            <div class="contact-info-block-two two">
              <div class="contact-info-inner-block-two">
                <div class="contact-info-title-block-two">
                  <h3 class="form-title-two">Contact Information</h3>
                </div>
                <div class="contact-info-content-block-two">
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two two">
                      <div class="contact-info-icon-two">
                        <svg width="22" height="22" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M16.95 18C14.8667 18 12.8083 17.546 10.775 16.638C8.74167 15.73 6.89167 14.4423 5.225 12.775C3.55833 11.1077 2.271 9.25767 1.363 7.225C0.455 5.19233 0.000666667 3.134 0 1.05C0 0.75 0.0999999 0.5 0.3 0.3C0.5 0.0999999 0.75 0 1.05 0H5.1C5.33333 0 5.54167 0.0793332 5.725 0.238C5.90833 0.396667 6.01667 0.584 6.05 0.8L6.7 4.3C6.73333 4.56667 6.725 4.79167 6.675 4.975C6.625 5.15833 6.53333 5.31667 6.4 5.45L3.975 7.9C4.30833 8.51667 4.704 9.11233 5.162 9.687C5.62 10.2617 6.12433 10.816 6.675 11.35C7.19167 11.8667 7.73333 12.346 8.3 12.788C8.86667 13.23 9.46667 13.634 10.1 14L12.45 11.65C12.6 11.5 12.796 11.3877 13.038 11.313C13.28 11.2383 13.5173 11.2173 13.75 11.25L17.2 11.95C17.4333 12.0167 17.625 12.1377 17.775 12.313C17.925 12.4883 18 12.684 18 12.9V16.95C18 17.25 17.9 17.5 17.7 17.7C17.5 17.9 17.25 18 16.95 18Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">PHONE</div>
                      <a href="tel:+(555)123456789" class="contact-info-text-two">+(555) 123456789</a>
                    </div>
                  </div>
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two two">
                      <div class="contact-info-icon-two">
                        <svg width="22" height="18" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M18 0H2C0.9 0 0.00999999 0.9 0.00999999 2L0 14C0 15.1 0.9 16 2 16H18C19.1 16 20 15.1 20 14V2C20 0.9 19.1 0 18 0ZM17.6 4.25L10.53 8.67C10.21 8.87 9.79 8.87 9.47 8.67L2.4 4.25C2.29973 4.19371 2.21192 4.11766 2.14189 4.02645C2.07186 3.93525 2.02106 3.83078 1.99258 3.71937C1.96409 3.60796 1.9585 3.49194 1.97616 3.37831C1.99381 3.26468 2.03434 3.15581 2.09528 3.0583C2.15623 2.96079 2.23632 2.87666 2.33073 2.811C2.42513 2.74533 2.53187 2.69951 2.6445 2.6763C2.75712 2.65309 2.87328 2.65297 2.98595 2.67595C3.09863 2.69893 3.20546 2.74453 3.3 2.81L10 7L16.7 2.81C16.7945 2.74453 16.9014 2.69893 17.014 2.67595C17.1267 2.65297 17.2429 2.65309 17.3555 2.6763C17.4681 2.69951 17.5749 2.74533 17.6693 2.811C17.7637 2.87666 17.8438 2.96079 17.9047 3.0583C17.9657 3.15581 18.0062 3.26468 18.0238 3.37831C18.0415 3.49194 18.0359 3.60796 18.0074 3.71937C17.9789 3.83078 17.9281 3.93525 17.8581 4.02645C17.7881 4.11766 17.7003 4.19371 17.6 4.25Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">EMAIL</div>
                      <a href="mailto:info@example.com" class="contact-info-text-two">info@example.com</a>
                    </div>
                  </div>
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two two">
                      <div class="contact-info-icon-two">
                        <svg width="16" height="22" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M7 9.5C6.33696 9.5 5.70107 9.23661 5.23223 8.76777C4.76339 8.29893 4.5 7.66304 4.5 7C4.5 6.33696 4.76339 5.70107 5.23223 5.23223C5.70107 4.76339 6.33696 4.5 7 4.5C7.66304 4.5 8.29893 4.76339 8.76777 5.23223C9.23661 5.70107 9.5 6.33696 9.5 7C9.5 7.3283 9.43534 7.65339 9.3097 7.95671C9.18406 8.26002 8.99991 8.53562 8.76777 8.76777C8.53562 8.99991 8.26002 9.18406 7.95671 9.3097C7.65339 9.43534 7.3283 9.5 7 9.5ZM7 0C5.14348 0 3.36301 0.737498 2.05025 2.05025C0.737498 3.36301 0 5.14348 0 7C0 12.25 7 20 7 20C7 20 14 12.25 14 7C14 5.14348 13.2625 3.36301 11.9497 2.05025C10.637 0.737498 8.85652 0 7 0Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">Main Office</div>
                      <p class="contact-info-text-two text">123 Legal Plaza, Suite 1000<br/>New York, NY 10001</p>
                    </div>
                  </div>
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two two">
                      <div class="contact-info-icon-two">
                        <svg width="16" height="22" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M7 9.5C6.33696 9.5 5.70107 9.23661 5.23223 8.76777C4.76339 8.29893 4.5 7.66304 4.5 7C4.5 6.33696 4.76339 5.70107 5.23223 5.23223C5.70107 4.76339 6.33696 4.5 7 4.5C7.66304 4.5 8.29893 4.76339 8.76777 5.23223C9.23661 5.70107 9.5 6.33696 9.5 7C9.5 7.3283 9.43534 7.65339 9.3097 7.95671C9.18406 8.26002 8.99991 8.53562 8.76777 8.76777C8.53562 8.99991 8.26002 9.18406 7.95671 9.3097C7.65339 9.43534 7.3283 9.5 7 9.5ZM7 0C5.14348 0 3.36301 0.737498 2.05025 2.05025C0.737498 3.36301 0 5.14348 0 7C0 12.25 7 20 7 20C7 20 14 12.25 14 7C14 5.14348 13.2625 3.36301 11.9497 2.05025C10.637 0.737498 8.85652 0 7 0Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">Office Hours</div>
                      <p class="contact-info-text-two text">Monday - Friday: 9:00 AM - 6:00 PM<br/>Saturday - Sunday: Closed</p>
                    </div>
                  </div>
                </div>
                <div class="contact-social-info-block">
                  <a aria-label="LinkedIn" href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="contact-social-icon-block">
                    <div class="contact-social-icon"><svg width="21" height="21" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M13.8994 6.77344C15.2255 6.77344 16.4973 7.30022 17.4349 8.2379C18.3726 9.17559 18.8994 10.4474 18.8994 11.7734V17.6068H15.5661V11.7734C15.5661 11.3314 15.3905 10.9075 15.0779 10.5949C14.7654 10.2824 14.3414 10.1068 13.8994 10.1068C13.4574 10.1068 13.0335 10.2824 12.7209 10.5949C12.4083 10.9075 12.2327 11.3314 12.2327 11.7734V17.6068H8.89941V11.7734C8.89941 10.4474 9.4262 9.17559 10.3639 8.2379C11.3016 7.30022 12.5733 6.77344 13.8994 6.77344Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M5.56673 7.60547H2.2334V17.6055H5.56673V7.60547Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M3.90007 5.10677C4.82054 5.10677 5.56673 4.36058 5.56673 3.4401C5.56673 2.51963 4.82054 1.77344 3.90007 1.77344C2.97959 1.77344 2.2334 2.51963 2.2334 3.4401C2.2334 4.36058 2.97959 5.10677 3.90007 5.10677Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg></div>
                  </a>
                  <a aria-label="Facebook" href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="contact-social-icon-block">
                    <div class="contact-social-icon"><svg width="12" height="20" viewBox="0 0 12 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M10.5661 1.77344H8.06608C6.96101 1.77344 5.9012 2.21242 5.1198 2.99383C4.3384 3.77523 3.89941 4.83504 3.89941 5.9401V8.4401H1.39941V11.7734H3.89941V18.4401H7.23275V11.7734H9.73275L10.5661 8.4401H7.23275V5.9401C7.23275 5.71909 7.32054 5.50713 7.47682 5.35085C7.6331 5.19457 7.84507 5.10677 8.06608 5.10677H10.5661V1.77344Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg></div>
                  </a>
                  <a aria-label="Instagram" href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="contact-social-icon-block">
                    <div class="contact-social-icon"><svg width="21" height="21" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M14.7334 1.77344H6.40006C4.09888 1.77344 2.2334 3.63892 2.2334 5.9401V14.2734C2.2334 16.5746 4.09888 18.4401 6.40006 18.4401H14.7334C17.0346 18.4401 18.9001 16.5746 18.9001 14.2734V5.9401C18.9001 3.63892 17.0346 1.77344 14.7334 1.77344Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M13.9001 9.57877C14.003 10.2723 13.8845 10.9806 13.5616 11.6029C13.2387 12.2253 12.7278 12.7299 12.1015 13.0452C11.4752 13.3604 10.7655 13.4701 10.0733 13.3587C9.38108 13.2473 8.74161 12.9205 8.24585 12.4247C7.75008 11.929 7.42326 11.2895 7.31187 10.5973C7.20048 9.90506 7.3102 9.19535 7.62542 8.56908C7.94064 7.94281 8.4453 7.43188 9.06763 7.10897C9.68997 6.78605 10.3983 6.66759 11.0918 6.77043C11.7992 6.87534 12.4542 7.20499 12.9599 7.71069C13.4656 8.21639 13.7952 8.87133 13.9001 9.57877Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M15.1499 5.52344H15.1582" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg></div>
                  </a>
                </div>
              </div>
            </div>
            <div class="contact-location-block">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.1838655752844!2d-73.9857363!3d40.7484405!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c259a9b3117469%3A0xd134e199a405a163!2sEmpire%20State%20Building!5e0!3m2!1sen!2sus!4v1710000000000!5m2!1sen!2sus"
                class="contact-map"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Office Location"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const scrollStart = 'top 90%';

  // === slideInBottom animations matching IX2 delays ===
  const elements = [
    { selector: '#Contact-Us-Two .contact-form-block-two', delay: 0.2 },
    { selector: '#Contact-Us-Two .contact-information-block-two', delay: 0.4 },
  ];

  elements.forEach(({ selector, delay }) => {
    const el = document.querySelector(selector) as HTMLElement;
    if (!el) return;
    gsap.set(el, { opacity: 0, y: 100 });
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      delay,
      scrollTrigger: { trigger: el, start: scrollStart, once: true },
    });
  });
</script>
