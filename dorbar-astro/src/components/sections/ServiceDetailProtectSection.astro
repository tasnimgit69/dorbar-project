---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { resolveImage } from '../../utils/resolveImage';

interface Props {
  image: string;
  title: string;
  items: { title: string; description: string }[];
}

const { image, title, items } = Astro.props;
---

<section class="protect-section" id="Protect-Section">
  <div class="container-default">
    <div class="protect-wrapper">
      <div class="protect-image-block">
        <Image src={resolveImage(image) as ImageMetadata} loading="lazy" alt={title} class="protect-image" width={600} height={700} />
      </div>
      <div class="protect-content-block">
        <div class="protect-content">
          <h2>{title}</h2>
          {items.map((item) => (
            <>
              <strong>{item.title}</strong>
              {item.description && <p>{item.description}</p>}
            </>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('#Protect-Section');
  if (section) {
    const imageBlock = section.querySelector('.protect-image-block');
    const content = section.querySelector('.protect-content');

    if (imageBlock) {
      gsap.fromTo(imageBlock, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, ease: 'power3.out',
        scrollTrigger: { trigger: imageBlock, start: 'top 90%', once: true }
      });
    }

    if (content) {
      gsap.fromTo(content, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: content, start: 'top 90%', once: true }
      });
    }
  }
</script>
