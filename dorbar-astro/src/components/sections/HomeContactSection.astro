---
import { businessHours } from '../../data/home';
---

<section id="Contact-Us-Two" class="contact-us-section">
  <div class="section-gap-two top">
    <div class="container-default">
      <div class="contact-us-wrapper-two">
        <div class="contact-heading-block-two">
          <div class="section-subtitle-block-two">
            <div class="section-subtitle-liner-one" aria-hidden="true"></div>
            <span class="section-subtitle-text-two">CONTACT US</span>
            <div class="section-subtitle-liner-two" aria-hidden="true"></div>
          </div>
          <div class="section-title-block-two">
            <h2 class="section-title-two">Schedule Your <span class="section-highlight-title-two">Consultation</span></h2>
          </div>
          <div class="section-summary-block-two max-w-600">
            <p class="section-summary-two">Reach out to our team of experienced attorneys for personalized legal guidance and strategic counsel tailored to your unique needs.</p>
          </div>
        </div>

        <div class="contact-content-block-two">
          <!-- Contact Form -->
          <div class="contact-form-sticky-block-two">
            <div class="contact-form-block-two">
              <div class="contact-form-liner-block" aria-hidden="true"></div>
              <div class="contact-form-two">
                <form class="contact-form-inner-two" method="post">
                  <div class="contact-form-content-block-two">
                    <div class="form-title-block-two">
                      <h3 class="form-title-two">Send Us Message</h3>
                    </div>

                    <div class="form-field-block-two">
                      <label for="contact-name" class="form-field-label-two">Full Name</label>
                      <input class="form-text-field-two" type="text" name="name" id="contact-name" placeholder="John Doe" required autocomplete="name" />
                    </div>

                    <div class="form-field-block-two">
                      <label for="contact-email" class="form-field-label-two">Email Address</label>
                      <input class="form-text-field-two" type="email" name="email" id="contact-email" placeholder="john@example.com" required autocomplete="email" />
                    </div>

                    <div class="form-field-block-two">
                      <label for="contact-phone" class="form-field-label-two">Phone Number</label>
                      <input class="form-text-field-two" type="tel" name="phone" id="contact-phone" placeholder="(123) 4567-890" required autocomplete="tel" />
                    </div>

                    <div class="form-field-block-two">
                      <label for="contact-message" class="form-field-label-two">Your Message</label>
                      <textarea class="form-text-field-two lg" name="message" id="contact-message" placeholder="Please describe your legal matter briefly..." maxlength="5000"></textarea>
                    </div>
                  </div>
                  <div class="form-button-block-two">
                    <button type="submit" class="form-button two">Send Message</button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <!-- Contact Information -->
          <div class="contact-information-block-two">
            <div class="contact-info-block-two">
              <div class="contact-info-inner-block-two">
                <div class="contact-info-title-block-two">
                  <h3 class="form-title-two">Get in Touch</h3>
                </div>
                <div class="contact-info-content-block-two">
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two">
                      <div class="contact-info-icon-two">
                        <svg width="22" height="22" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M16.95 18C14.8667 18 12.8083 17.546 10.775 16.638C8.74167 15.73 6.89167 14.4423 5.225 12.775C3.55833 11.1077 2.271 9.25767 1.363 7.225C.455 5.19233.000666667 3.134 0 1.05C0 .75.0999999.5.3.3C.5.0999999.75 0 1.05 0H5.1C5.33333 0 5.54167.0793332 5.725.238C5.90833.396667 6.01667.584 6.05.8L6.7 4.3C6.73333 4.56667 6.725 4.79167 6.675 4.975C6.625 5.15833 6.53333 5.31667 6.4 5.45L3.975 7.9C4.30833 8.51667 4.704 9.11233 5.162 9.687C5.62 10.2617 6.12433 10.816 6.675 11.35C7.19167 11.8667 7.73333 12.346 8.3 12.788C8.86667 13.23 9.46667 13.634 10.1 14L12.45 11.65C12.6 11.5 12.796 11.3877 13.038 11.313C13.28 11.2383 13.5173 11.2173 13.75 11.25L17.2 11.95C17.4333 12.0167 17.625 12.1377 17.775 12.313C17.925 12.4883 18 12.684 18 12.9V16.95C18 17.25 17.9 17.5 17.7 17.7C17.5 17.9 17.25 18 16.95 18Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">PHONE</div>
                      <a href="tel:+(555)123456789" class="contact-info-text-two">+(555) 123456789</a>
                    </div>
                  </div>
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two">
                      <div class="contact-info-icon-two">
                        <svg width="22" height="18" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M18 0H2C.9 0 0 .9 0 2V14C0 15.1.9 16 2 16H18C19.1 16 20 15.1 20 14V2C20 .9 19.1 0 18 0ZM17.6 4.25L10.53 8.67C10.21 8.87 9.79 8.87 9.47 8.67L2.4 4.25C2.29973 4.19371 2.21192 4.11766 2.14189 4.02645C2.07186 3.93525 2.02106 3.83078 1.99258 3.71937C1.96409 3.60796 1.9585 3.49194 1.97616 3.37831C1.99381 3.26468 2.03434 3.15581 2.09528 3.0583C2.15623 2.96079 2.23632 2.87666 2.33073 2.811C2.42513 2.74533 2.53187 2.69951 2.6445 2.6763C2.75712 2.65309 2.87328 2.65297 2.98595 2.67595C3.09863 2.69893 3.20546 2.74453 3.3 2.81L10 7L16.7 2.81C16.7945 2.74453 16.9014 2.69893 17.014 2.67595C17.1267 2.65297 17.2429 2.65309 17.3555 2.6763C17.4681 2.69951 17.5749 2.74533 17.6693 2.811C17.7637 2.87666 17.8438 2.96079 17.9047 3.0583C17.9657 3.15581 18.0062 3.26468 18.0238 3.37831C18.0415 3.49194 18.0359 3.60796 18.0074 3.71937C17.9789 3.83078 17.9281 3.93525 17.8581 4.02645C17.7881 4.11766 17.7003 4.19371 17.6 4.25Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">EMAIL</div>
                      <a href="mailto:info@example.com" class="contact-info-text-two">info@example.com</a>
                    </div>
                  </div>
                  <div class="contact-single-info-block-two">
                    <div class="contact-info-icon-block-two">
                      <div class="contact-info-icon-two">
                        <svg width="16" height="22" viewBox="0 0 14 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M7 9.5C6.33696 9.5 5.70107 9.23661 5.23223 8.76777C4.76339 8.29893 4.5 7.66304 4.5 7C4.5 6.33696 4.76339 5.70107 5.23223 5.23223C5.70107 4.76339 6.33696 4.5 7 4.5C7.66304 4.5 8.29893 4.76339 8.76777 5.23223C9.23661 5.70107 9.5 6.33696 9.5 7C9.5 7.3283 9.43534 7.65339 9.3097 7.95671C9.18406 8.26002 8.99991 8.53562 8.76777 8.76777C8.53562 8.99991 8.26002 9.18406 7.95671 9.3097C7.65339 9.43534 7.3283 9.5 7 9.5ZM7 0C5.14348 0 3.36301 0.737498 2.05025 2.05025C0.737498 3.36301 0 5.14348 0 7C0 12.25 7 20 7 20C7 20 14 12.25 14 7C14 5.14348 13.2625 3.36301 11.9497 2.05025C10.637 0.737498 8.85652 0 7 0Z" fill="currentColor"/>
                        </svg>
                      </div>
                    </div>
                    <div class="contact-info-text-block-two">
                      <div class="contact-info-title-text-two">OFFICE ADDRESS</div>
                      <p class="contact-info-text-two text">123 Legan Plaza, Suite 1000<br />New York, NY 10001</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="contact-location-block">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.1838655752844!2d-73.9857363!3d40.7484405!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c259a9b3117469%3A0xd134e199a405a163!2sEmpire%20State%20Building!5e0!3m2!1sen!2sus!4v1710000000000!5m2!1sen!2sus"
                class="contact-map"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Office Location"
              ></iframe>
            </div>

            <div class="contact-time-info-block">
              <div class="contact-time-title-block">
                <h3 class="form-title-two">Business Hours</h3>
              </div>
              <div class="contact-time-scedule-block top-24px-gap">
                {businessHours.map((item) => (
                  <div class="single-time-scedule-block">
                    <p class="scedule-day-text">{item.day}</p>
                    <p class="scedule-time-text">{item.time}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const scrollStart = 'top 90%';

  // === Heading elements: slideInBottom (IX2 preset) ===
  const headingElements = [
    { selector: '#Contact-Us-Two .section-subtitle-block-two', delay: 0.1 },
    { selector: '#Contact-Us-Two .section-title-block-two', delay: 0.2 },
    { selector: '#Contact-Us-Two .section-summary-block-two', delay: 0.3 },
  ];

  headingElements.forEach(({ selector, delay }) => {
    const el = document.querySelector(selector) as HTMLElement;
    if (!el) return;
    gsap.set(el, { opacity: 0, y: 100 });
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      delay,
      scrollTrigger: { trigger: el, start: scrollStart, once: true },
    });
  });

  // === Form block: slideInBottom ===
  const formBlock = document.querySelector('#Contact-Us-Two .contact-form-block-two') as HTMLElement;
  if (formBlock) {
    gsap.set(formBlock, { opacity: 0, y: 100 });
    gsap.to(formBlock, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      delay: 0.2,
      scrollTrigger: { trigger: formBlock, start: 'top 93%', once: true },
    });
  }

  // === Information block: slideInBottom ===
  const infoBlock = document.querySelector('#Contact-Us-Two .contact-information-block-two') as HTMLElement;
  if (infoBlock) {
    gsap.set(infoBlock, { opacity: 0, y: 100 });
    gsap.to(infoBlock, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      delay: 0.4,
      scrollTrigger: { trigger: infoBlock, start: scrollStart, once: true },
    });
  }

  // === Form liner marquee loop (IX2 a-19) ===
  const formLiner = document.querySelector('#Contact-Us-Two .contact-form-liner-block') as HTMLElement;
  if (formLiner) {
    const tl = gsap.timeline({ repeat: -1 });
    tl.set(formLiner, { x: '-100%' });
    tl.to(formLiner, { x: '100%', duration: 2, ease: 'none' });
  }
</script>
