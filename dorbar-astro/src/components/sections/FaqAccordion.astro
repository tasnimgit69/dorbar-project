---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  variant?: string;
  numbered?: boolean;
}

const { items, variant, numbered = true } = Astro.props;
const contentClass = variant ? `faq-content-block ${variant}` : 'faq-content-block';
---

<div class={contentClass}>
  {items.map((item, index) => (
    <div class="service-single-faq-block">
      <button
        class="service-faq-toggle"
        aria-expanded="false"
        aria-controls={`faq-content-${index}`}
      >
        <span class="service-faq-item-title">{numbered ? `${index + 1}. ${item.question}` : item.question}</span>
        <span class="service-faq-icon-block" aria-hidden="true">
          <svg class="service-faq-icon" width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 4.33984V14.8398" stroke="#C5A46D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M3.75 9.58984H14.25" stroke="#C5A46D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>
      <div
        class="service-faq-content"
        id={`faq-content-${index}`}
        role="region"
        hidden
      >
        <div class="service-faq-content-inner">
          <p class="service-faq-item-answer">{item.answer}</p>
        </div>
      </div>
    </div>
  ))}
  <slot />
</div>

<script>
  import { gsap } from 'gsap';

  document.querySelectorAll('.service-faq-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const button = toggle as HTMLButtonElement;
      const isOpen = button.getAttribute('aria-expanded') === 'true';
      const contentId = button.getAttribute('aria-controls');
      const content = document.getElementById(contentId!) as HTMLElement;
      const icon = button.querySelector('.service-faq-icon') as SVGElement;
      const parent = button.closest('.service-single-faq-block') as HTMLElement;

      if (isOpen) {
        // Close
        button.setAttribute('aria-expanded', 'false');
        gsap.to(content, {
          height: 0,
          duration: 0.4,
          ease: 'power2.inOut',
          onComplete: () => {
            content.hidden = true;
          },
        });
        gsap.to(icon, { rotation: 0, duration: 0.3 });
        parent.classList.remove('is-open');
      } else {
        // Open
        button.setAttribute('aria-expanded', 'true');
        content.hidden = false;
        content.style.height = '0px';
        content.style.overflow = 'hidden';

        const naturalHeight = content.scrollHeight;
        gsap.to(content, {
          height: naturalHeight,
          duration: 0.4,
          ease: 'power2.out',
          onComplete: () => {
            content.style.height = 'auto';
            content.style.overflow = '';
          },
        });
        gsap.to(icon, { rotation: 45, duration: 0.3 });
        parent.classList.add('is-open');
      }
    });
  });
</script>
