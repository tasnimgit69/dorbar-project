---
interface ApproachStep {
  title: string;
  description: string;
}

interface Props {
  approach: ApproachStep[];
}

const { approach } = Astro.props;
const lastIndex = approach.length - 1;
---

<section class="approach-section">
  <div class="container-default">
    <div class="approach-wrapper">
      <div class="approach-heading-block">
        <h2 class="section-title-two">Our Strategic Approach</h2>
      </div>
      <div class="approach-content-block">
        {approach.map((step, i) => (
          <div class={`approach-single-content-block${i === 0 ? ' is-1' : ''}${i === lastIndex ? ' is-3' : ''}`}>
            <div class="approach-content-number-block">
              <div class="approach-content-number">{String(i + 1).padStart(2, '0')}</div>
            </div>
            <div class="approach-content-text-block">
              <div class="approach-single-content-text">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.approach-section');
    if (!section) return;

    const heading = section.querySelector('.section-title-two');
    const blocks = section.querySelectorAll('.approach-single-content-block');

    gsap.set(heading, { y: 100, opacity: 0 });
    gsap.to(heading, {
      y: 0, opacity: 1, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: section, start: 'top 80%', once: true }
    });

    blocks.forEach((block, i) => {
      gsap.set(block, { y: 100, opacity: 0 });
      gsap.to(block, {
        y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: (i + 1) * 0.2,
        scrollTrigger: { trigger: section, start: 'top 80%', once: true }
      });
    });
  });
</script>
