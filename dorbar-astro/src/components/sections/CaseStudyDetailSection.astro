---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { resolveImage } from '../../utils/resolveImage';

interface Props {
  title: string;
  situation: string;
  mainImage: string;
}

const { title, situation, mainImage } = Astro.props;
---

<section class="challenge-section">
  <div class="section-gap-two">
    <div class="container-default">
      <div class="challenge-wrapper">
        <div class="challenge-heading-block">
          <div class="challenge-title-block">
            <h2 class="section-title-two">Background & Challenge</h2>
          </div>
        </div>
        <div class="challenge-content-block">
          <div class="challenge-text-block">
            <div class="challenge-section-text">
              <h3>The Situation</h3>
              {situation.split('\n\n').map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
          <div class="challenge-image-block">
            <Image src={resolveImage(mainImage) as ImageMetadata} loading="lazy" alt="Challenge Image" class="challenge-image" width={670} height={780} />
            <div class="about-liner"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.challenge-section');
    if (!section) return;

    const heading = section.querySelector('.section-title-two');
    const text = section.querySelector('.challenge-section-text');
    const image = section.querySelector('.challenge-image');
    const liner = section.querySelector('.about-liner');

    // Heading slideInBottom (delay 200ms)
    gsap.set(heading, { y: 100, opacity: 0 });
    gsap.to(heading, {
      y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.2,
      scrollTrigger: { trigger: section, start: 'top 80%', once: true }
    });

    // Text slideInBottom (delay 300ms)
    gsap.set(text, { y: 100, opacity: 0 });
    gsap.to(text, {
      y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.3,
      scrollTrigger: { trigger: section, start: 'top 80%', once: true }
    });

    // Image slideInBottom (delay 500ms)
    gsap.set(image, { y: 100, opacity: 0 });
    gsap.to(image, {
      y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.5,
      scrollTrigger: { trigger: section, start: 'top 80%', once: true }
    });

    // Liner scaleY reveal (delay 800ms, duration 1s, outCubic)
    gsap.set(liner, { scaleY: 0, transformOrigin: 'center bottom' });
    gsap.to(liner, {
      scaleY: 1, duration: 1, ease: 'power3.out', delay: 0.8,
      scrollTrigger: { trigger: section, start: 'top 80%', once: true }
    });
  });
</script>
