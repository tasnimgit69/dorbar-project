---
import { journeyTimeline } from '../../data/journeyTimeline';
---

<section class="journey-section" id="Journey-Section">
  <div class="section-gap-two">
    <div class="container-default">
      <div class="journey-wrapper">
        <div class="journey-title-block is-2">
          <h2 class="section-title-two">Our Journey Through the Years</h2>
        </div>
        <div class="journey-content-block">
          <div class="journey-left-block">
            {journeyTimeline.filter((_, i) => i % 2 === 0).map((entry) => (
              <div class="single-journey-block">
                <div class="journey-year">{entry.year}</div>
                <p class="journey-text">{entry.description}</p>
              </div>
            ))}
          </div>
          <div class="journey-liner-block">
            <div class="journey-color-liner"></div>
            {journeyTimeline.map((_, i) => (
              <div class={`journey-liner-point is-${i + 1}`}>
                <div class="journey-liner-sm-point"></div>
              </div>
            ))}
          </div>
          <div class="journey-right-block">
            {journeyTimeline.filter((_, i) => i % 2 !== 0).map((entry) => (
              <div class="single-journey-block is-2">
                <div class="journey-year">{entry.year}</div>
                <p class="journey-text is-2">{entry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const scrollStart = 'top 90%';

  // === Title: slideInBottom ===
  const title = document.querySelector('#Journey-Section .section-title-two') as HTMLElement;
  if (title) {
    gsap.set(title, { opacity: 0, y: 100 });
    gsap.to(title, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      delay: 0.1,
      scrollTrigger: { trigger: title, start: scrollStart, once: true },
    });
  }

  // === Content block: slideInBottom ===
  const contentBlock = document.querySelector('#Journey-Section .journey-content-block') as HTMLElement;
  if (contentBlock) {
    gsap.set(contentBlock, { opacity: 0, y: 100 });
    gsap.to(contentBlock, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      delay: 0.2,
      scrollTrigger: { trigger: contentBlock, start: scrollStart, once: true },
    });
  }

  // === Color liner: scaleY scrubs with scroll progress ===
  const colorLiner = document.querySelector('#Journey-Section .journey-color-liner') as HTMLElement;
  const linerBlock = document.querySelector('#Journey-Section .journey-liner-block') as HTMLElement;
  if (colorLiner && linerBlock) {
    gsap.set(colorLiner, { scaleY: 0 });
    gsap.to(colorLiner, {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: {
        trigger: linerBlock,
        start: 'top 80%',
        end: 'bottom 20%',
        scrub: true,
      },
    });
  }
</script>
