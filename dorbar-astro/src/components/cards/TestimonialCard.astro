---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { resolveImage } from '../../utils/resolveImage';

interface Props {
  name: string;
  designation: string;
  quote: string;
  avatar: string;
  rating?: number;
}

const { name, designation, quote, avatar, rating = 5 } = Astro.props;
const resolvedAvatar = resolveImage(avatar) as ImageMetadata;
const starIcon = resolveImage('/images/icons/testimonial-star-icon.svg') as ImageMetadata;
---

<div class="testimonial-card-block-two">
  <div class="testimonial-card-inner-block-two">
    <div class="testimonial-gt-liner-block" aria-hidden="true"></div>

    <!-- Star Rating -->
    <div class="testimonial-star-block-two" aria-label={`${rating} out of 5 stars`}>
      {Array.from({ length: rating }).map(() => (
        <Image src={starIcon} alt="" class="star-icon" width={18} height={18} loading="lazy" />
      ))}
    </div>

    <!-- Quote -->
    <div class="testimonial-text-block top-16px-gap">
      <div class="testimonial-text-two">&ldquo;{quote}&rdquo;</div>
    </div>

    <!-- Client Info -->
    <div class="client-info-block-two">
      <div class="client-avatar-block-two">
        <Image src={resolvedAvatar} alt={`${name} photo`} class="client-avatar-two" width={60} height={60} loading="lazy" />
      </div>
      <div class="client-info-text-block-two">
        <div class="client-name-two">{name}</div>
        <p class="client-designation-two">{designation}</p>
      </div>
    </div>
  </div>
</div>
