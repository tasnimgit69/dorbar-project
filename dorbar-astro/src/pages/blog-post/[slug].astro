---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { blogPosts } from '../../data/blogPosts';
import type { GetStaticPaths } from 'astro';
import { resolveImage } from '../../utils/resolveImage';
import RelatedPostsSection from '../../components/sections/RelatedPostsSection.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { siteConfig } from '../../data/siteConfig';

export const getStaticPaths: GetStaticPaths = () => {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const relatedPosts = blogPosts.filter((p) => p.slug !== post.slug).slice(0, 3);

const clockIcon = resolveImage('/images/icons/clock-icon.svg') as ImageMetadata;
const userIcon = resolveImage('/images/icons/user-icon.svg') as ImageMetadata;
const bookIcon = resolveImage('/images/icons/book-icon.svg') as ImageMetadata;

const heroImageResolved = resolveImage(post.heroImage || post.image) as ImageMetadata;
const heroImageUrl = typeof heroImageResolved === 'string' ? heroImageResolved : heroImageResolved.src;

// Resolve inline content images from src/assets
const detailsImageResolved = resolveImage('/images/blog/blog-details-image.webp') as ImageMetadata;
const detailsImageUrl = typeof detailsImageResolved === 'string' ? detailsImageResolved : detailsImageResolved.src;
const resolvedContent = post.content.replaceAll('/images/blog/blog-details-image.webp', detailsImageUrl);
const resolvedContentTwo = post.contentTwo?.replaceAll('/images/blog/blog-details-image.webp', detailsImageUrl);

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.summary,
  "datePublished": post.date,
  "author": { "@type": "Person", "name": post.author },
  "publisher": { "@type": "Organization", "name": "Dorbar & Associates" },
  "image": heroImageUrl,
};
---

<PageLayout
  title={`${post.title} | Dorbar Law Firm`}
  description={post.summary}
  schema={blogSchema}
>
  <!-- Blog Details Hero -->
  <section class="blog-details-hero-section" style={`background-image: url(${heroImageUrl});`}>
    <div class="blog-details-hero-gap">
      <div class="container-default">
        <div class="blog-details-hero-wrapper">
          <div class="blog-details-hero-content-block">
            <div class="blog-details-hero-text-block">
              <a href={`/blog-categories/${post.categorySlug}`} class="blog-category-text blog-details">{post.category}</a>
              <h1 class="page-intro middle">{post.title}</h1>
            </div>
            <div class="blog-details-hero-info-block">
              <div class="blog-details-single-info-block">
                <div class="blog-details-info-icon-block">
                  <Image src={userIcon} loading="lazy" alt="Blog Details Info Icon" class="blog-details-info-icon" width={20} height={20} />
                </div>
                <div class="blog-details-info-text-block">
                  <p class="blog-details-info-text">By </p>
                  <p class="blog-details-info-text">{post.author}</p>
                </div>
              </div>
              <div class="blog-details-single-info-block">
                <div class="blog-details-info-icon-block">
                  <Image src={clockIcon} loading="lazy" alt="Blog Details Info Icon" class="blog-details-info-icon" width={20} height={20} />
                </div>
                <div class="blog-details-info-text-block">
                  <p class="blog-details-info-text">{post.date}</p>
                </div>
              </div>
              <div class="blog-details-single-info-block">
                <div class="blog-details-info-icon-block">
                  <Image src={bookIcon} loading="lazy" alt="Blog Details Info Icon" class="blog-details-info-icon" width={20} height={20} />
                </div>
                <div class="blog-details-info-text-block">
                  <p class="blog-details-info-text">{post.readTime}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Details Content -->
  <section class="blog-details-section" id="Blog-Details-Section">
    <div class="section-gap-two">
      <div class="container-default">
        <div class="blog-details-wrapper">
          <div class="details-hero-text-block">
            <p class="details-hero-text">{post.detailSummary || post.summary}</p>
          </div>
          <div class="blog-details-text-one w-richtext" set:html={resolvedContent} />
          {resolvedContentTwo && (
            <div class="blog-details-text-two w-richtext" set:html={resolvedContentTwo} />
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Key Takeaways -->
  <section class="takeaway-section" id="Takeaway-Section">
    <div class="section-gap-two">
      <div class="container-default">
        <div class="takeaway-wrapper">
          <div class="takeaway-heading-block">
            <h2 class="section-title-two">Key Takeaways</h2>
          </div>
          <div class="takeaway-content-block">
            {post.keyTakeaways.map((takeaway) => (
              <div class="takeaway-point-block">
                <div class="takeaway-point-icon-block">
                  <img src="/images/icons/price-point-icon.svg" loading="lazy" alt="Takeaway Point Icon" class="takeaway-point-icon" />
                </div>
                <div class="takeaway-point-text-block">
                  <p class="takeaway-point-text">{takeaway}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Author Bio -->
  <section class="attorney-section" id="Blog-Author-Section">
    <div class="section-gap-two">
      <div class="container-default">
        <div class="attorney-wrapper blog">
          <div class="attorney-card-item-block blog">
            <div class="attorney-item-image-block blog">
              <Image src={resolveImage(post.authorImage) as ImageMetadata} loading="lazy" alt="Attorney Item Image" class="attorney-item-image blog" width={116} height={116} />
            </div>
            <div class="attorney-item-content-block blog">
              <div class="attorney-item-name-block">
                <h3 class="attorney-name">{post.author}</h3>
                <div class="attorney-designation">Managing Partner</div>
              </div>
              <div class="attorney-item-summary-block about">
                <p class="attorney-item-summary">{post.authorBio}</p>
              </div>
              <div class="attorney-item-bottom-block blog">
                <a aria-label="LinkedIn" href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="contact-social-icon-block">
                  <div class="contact-social-icon"><svg width="21" height="21" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M13.8994 6.77344C15.2255 6.77344 16.4973 7.30022 17.4349 8.2379C18.3726 9.17559 18.8994 10.4474 18.8994 11.7734V17.6068H15.5661V11.7734C15.5661 11.3314 15.3905 10.9075 15.0779 10.5949C14.7654 10.2824 14.3414 10.1068 13.8994 10.1068C13.4574 10.1068 13.0335 10.2824 12.7209 10.5949C12.4083 10.9075 12.2327 11.3314 12.2327 11.7734V17.6068H8.89941V11.7734C8.89941 10.4474 9.4262 9.17559 10.3639 8.2379C11.3016 7.30022 12.5733 6.77344 13.8994 6.77344Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M5.56673 7.60547H2.2334V17.6055H5.56673V7.60547Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M3.90007 5.10677C4.82054 5.10677 5.56673 4.36058 5.56673 3.4401C5.56673 2.51963 4.82054 1.77344 3.90007 1.77344C2.97959 1.77344 2.2334 2.51963 2.2334 3.4401C2.2334 4.36058 2.97959 5.10677 3.90007 5.10677Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg></div>
                </a>
                <a aria-label="Facebook" href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="contact-social-icon-block">
                  <div class="contact-social-icon"><svg width="12" height="20" viewBox="0 0 12 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M10.5661 1.77344H8.06608C6.96101 1.77344 5.9012 2.21242 5.1198 2.99383C4.3384 3.77523 3.89941 4.83504 3.89941 5.9401V8.4401H1.39941V11.7734H3.89941V18.4401H7.23275V11.7734H9.73275L10.5661 8.4401H7.23275V5.9401C7.23275 5.71909 7.32054 5.50713 7.47682 5.35085C7.6331 5.19457 7.84507 5.10677 8.06608 5.10677H10.5661V1.77344Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg></div>
                </a>
                <a aria-label="Instagram" href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="contact-social-icon-block">
                  <div class="contact-social-icon"><svg width="21" height="21" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M14.7334 1.77344H6.40006C4.09888 1.77344 2.2334 3.63892 2.2334 5.9401V14.2734C2.2334 16.5746 4.09888 18.4401 6.40006 18.4401H14.7334C17.0346 18.4401 18.9001 16.5746 18.9001 14.2734V5.9401C18.9001 3.63892 17.0346 1.77344 14.7334 1.77344Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M13.9001 9.57877C14.003 10.2723 13.8845 10.9806 13.5616 11.6029C13.2387 12.2253 12.7278 12.7299 12.1015 13.0452C11.4752 13.3604 10.7655 13.4701 10.0733 13.3587C9.38108 13.2473 8.74161 12.9205 8.24585 12.4247C7.75008 11.929 7.42326 11.2895 7.31187 10.5973C7.20048 9.90506 7.3102 9.19535 7.62542 8.56908C7.94064 7.94281 8.4453 7.43188 9.06763 7.10897C9.68997 6.78605 10.3983 6.66759 11.0918 6.77043C11.7992 6.87534 12.4542 7.20499 12.9599 7.71069C13.4656 8.21639 13.7952 8.87133 13.9001 9.57877Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M15.1499 5.52344H15.1582" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg></div>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  <RelatedPostsSection posts={relatedPosts} />

  <!-- CTA Section -->
  <CtaBanner
    title="Need Strategic Legal Representation?"
    summary="Contact our team today to discuss your legal challenges and discover how we can help protect your interests."
  />
  
</PageLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Hero animations
  const heroSection = document.querySelector('.blog-details-hero-section');
  if (heroSection) {
    const categoryTag = heroSection.querySelector('.blog-category-text');
    const title = heroSection.querySelector('.page-intro');
    const infoBlock = heroSection.querySelector('.blog-details-hero-info-block');

    if (categoryTag) {
      gsap.fromTo(categoryTag, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1, delay: 0.1, ease: 'power3.out' });
    }
    if (title) {
      gsap.fromTo(title, { opacity: 0, y: 100 }, { opacity: 1, y: 0, duration: 1, delay: 0.3, ease: 'power3.out' });
    }
    if (infoBlock) {
      gsap.fromTo(infoBlock, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1, delay: 0.5, ease: 'power3.out' });
    }
  }

  // Details content animations
  const detailsSection = document.querySelector('#Blog-Details-Section');
  if (detailsSection) {
    const heroText = detailsSection.querySelector('.details-hero-text-block');
    const textOne = detailsSection.querySelector('.blog-details-text-one');

    if (heroText) {
      gsap.fromTo(heroText, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: detailsSection, start: 'top 80%', once: true },
      });
    }
    if (textOne) {
      gsap.fromTo(textOne, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: 0.4, ease: 'power3.out',
        scrollTrigger: { trigger: detailsSection, start: 'top 80%', once: true },
      });
    }
  }

  // Takeaway animations
  const takeawaySection = document.querySelector('#Takeaway-Section');
  if (takeawaySection) {
    const heading = takeawaySection.querySelector('.section-title-two');
    const points = takeawaySection.querySelectorAll('.takeaway-point-block');

    if (heading) {
      gsap.fromTo(heading, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: takeawaySection, start: 'top 80%', once: true },
      });
    }

    points.forEach((point, i) => {
      gsap.fromTo(point, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: (i + 1) * 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: takeawaySection, start: 'top 80%', once: true },
      });
    });
  }

  // Author animation
  const authorSection = document.querySelector('#Blog-Author-Section');
  if (authorSection) {
    const card = authorSection.querySelector('.attorney-card-item-block.blog');
    if (card) {
      gsap.fromTo(card, { opacity: 0, y: 100 }, {
        opacity: 1, y: 0, duration: 1, delay: 0.2, ease: 'power3.out',
        scrollTrigger: { trigger: authorSection, start: 'top 80%', once: true },
      });
    }
  }

</script>
