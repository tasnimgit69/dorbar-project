---
import PageLayout from '../layouts/PageLayout.astro';
import AboutHeroSection from '../components/sections/AboutHeroSection.astro';
import WhoWeAreSection from '../components/sections/WhoWeAreSection.astro';
import OurPurposeSection from '../components/sections/OurPurposeSection.astro';
import JourneySection from '../components/sections/JourneySection.astro';
import LeadershipSection from '../components/sections/LeadershipSection.astro';
import AwardsSection from '../components/sections/AwardsSection.astro';
import AboutStatisticsSection from '../components/sections/AboutStatisticsSection.astro';
import AboutTestimonialsSection from '../components/sections/AboutTestimonialsSection.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
---

<PageLayout
