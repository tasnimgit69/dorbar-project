  description="Founded with a commitment to excellence and integrity, Dorbar & Associates has been guiding clients through complex legal matters for over two decades."
>
  <AboutHeroSection />
  <WhoWeAreSection />
  <OurPurposeSection />
  <JourneySection />
  <LeadershipSection />
  <AwardsSection />
  <AboutStatisticsSection />
  <AboutTestimonialsSection />
