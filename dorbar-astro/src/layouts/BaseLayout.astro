---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
}

const {
  title,
  description = 'Dorbar & Associates — A boutique law firm dedicated to excellence, integrity, and exceptional client service.',
  ogImage = '/og-image.png',
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index, follow" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.png" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/webclip.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiA.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://fonts.gstatic.com/s/playfairdisplay/v40/nuFiD-vYSZviVYUb_rj3ij__anPXDTnCjmHKM4nYO7KN_qiTbtbK-F2rA0s.woff2" as="font" type="font/woff2" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Attorney",
      "name": "Dorbar & Associates",
      "url": "https://example.com",
      "telephone": "+1-555-123-4567",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "123 Legan Plaza, Suite 1000",
        "addressLocality": "New York",
        "addressRegion": "NY",
        "postalCode": "10001",
        "addressCountry": "US"
      },
      "logo": "https://example.com/og-image.png"
    })} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <slot name="head" />
  </head>
  <body>
    <slot />

    <!-- GSAP -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Scroll-triggered animations
      const animateElements = document.querySelectorAll('[data-animate]');
      animateElements.forEach((el) => {
        const type = (el as HTMLElement).dataset.animate;
        const delay = parseFloat((el as HTMLElement).dataset.animateDelay || '0');

        const baseProps: gsap.TweenVars = {
          duration: 0.8,
          ease: 'power2.out',
          delay,
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            once: true,
          },
        };

        switch (type) {
          case 'fade-up':
            gsap.to(el, { ...baseProps, opacity: 1, y: 0 });
            break;
          case 'fade-in':
            gsap.to(el, { ...baseProps, opacity: 1 });
            break;
          case 'scale-in':
            gsap.to(el, { ...baseProps, opacity: 1, scale: 1 });
            break;
          case 'scale-x':
            gsap.to(el, { ...baseProps, opacity: 1, scaleX: 1, transformOrigin: 'left center' });
            break;
          case 'scale-y':
            gsap.to(el, { ...baseProps, opacity: 1, scaleY: 1, transformOrigin: 'center bottom' });
            break;
          default:
            gsap.to(el, { ...baseProps, opacity: 1, y: 0 });
        }
      });

      // Button hover glow effect — global
      document.querySelectorAll('.button-two, .secondaey-button-two').forEach((btn) => {
        const glow = btn.querySelector('.button-hover-glow') as HTMLElement;
        if (!glow) return;

        const isPrimary = btn.classList.contains('button-two');
        gsap.set(glow, { opacity: 0, scale: 0.3 });

        btn.addEventListener('mouseenter', () => {
          gsap.killTweensOf(glow);
          if (isPrimary) {
            gsap.to(glow, { opacity: 1, duration: 1, ease: 'power1.out' });
            gsap.to(glow, { scale: 10, duration: 0.8, delay: 0.2, ease: 'power1.out' });
          } else {
            gsap.to(glow, { opacity: 1, duration: 0.6, ease: 'power1.out' });
            gsap.to(glow, { scale: 10, duration: 0.6, ease: 'power1.in' });
          }
        });

        btn.addEventListener('mouseleave', () => {
          gsap.killTweensOf(glow);
          if (isPrimary) {
            gsap.to(glow, { scale: 0.3, duration: 0.6, ease: 'power1.out' });
            gsap.to(glow, { opacity: 0, duration: 1, delay: 0.2, ease: 'power1.out' });
          } else {
            gsap.to(glow, { scale: 0.3, duration: 0.6, ease: 'power1.out' });
            gsap.to(glow, { opacity: 0, duration: 0.8, delay: 0.2, ease: 'power1.out' });
          }
        });
      });
    </script>
  </body>
</html>
